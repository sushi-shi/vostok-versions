# Extracted installers: survarium.exe (tens of MB) + survarium.pdb (hundreds of MB).
cache/

# Raw installers dropped into the repo.
/installers/
*.exe
!scripts/**

__pycache__/
*.pyc
.ruff_cache/

# Delinked objects + structure stubs: large and deterministically
# regenerable from the pinned installers (flake + vostok-delinker), so the
# repo keeps the lean ledger (meta, symbol-map, diffs) and not the objects.
versions/*/objects/
versions/*/structure/

# Heavy/regenerable diff artifacts; keep the distilled summary.{md,json}.
diffs/*/report.json
diffs/*/dummy.obj
